<Window x:Class="chessTraim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шахматы"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#202020">

    <Grid>

        <!-- ФОН -->
        <Grid.Background>

            <ImageBrush ImageSource="Images/board.png"
                        Stretch="UniformToFill"
                        Opacity="0.20"/>

        </Grid.Background>

        <!-- ЦЕНТРАЛЬНАЯ ПАНЕЛЬ -->
        <Border Width="500"
                Height="500"
                Background="#AAFFFFFF"
                CornerRadius="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <!-- ЗАГОЛОВОК -->
                <TextBlock Text="ШАХМАТЫ"
                           FontSize="48"
                           FontWeight="Bold"
                           FontFamily="Oswald"
                           Foreground="#222222"
                           Margin="0,20,0,40"
                           HorizontalAlignment="Center"/>

                <!-- НОВАЯ ИГРА -->
                <Button Name="NewGameButton"
                        Content="Новая игра"
                        Width="320"
                        Height="65"
                        FontSize="24"
                        FontFamily="Oswald"
                        Margin="0,10"
                        Click="NewGameButton_Click"
                        Cursor="Hand">

                    <Button.Style>

                        <Style TargetType="Button">

                            <Setter Property="Background" Value="#66FFFFFF"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#222222"/>

                            <Setter Property="Template">

                                <Setter.Value>

                                    <ControlTemplate TargetType="Button">

                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="18">

                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>

                                        </Border>

                                        <ControlTemplate.Triggers>

                                            <!-- HOVER -->

                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#99FFFFFF"/>

                                                <Setter Property="FontSize"
                                                        Value="27"/>

                                            </Trigger>

                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>

                                </Setter.Value>

                            </Setter>

                        </Style>

                    </Button.Style>

                </Button>

                <!-- ПРОДОЛЖИТЬ -->
                <Button Name="ContinueButton"
                        Content="Продолжить игру"
                        Width="320"
                        Height="65"
                        FontSize="24"
                        FontFamily="Oswald"
                        Margin="0,10"
                        Click="ContinueButton_Click"
                        Cursor="Hand">

                    <Button.Style>

                        <Style TargetType="Button">

                            <Setter Property="Background" Value="#66FFFFFF"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#222222"/>

                            <Setter Property="Template">

                                <Setter.Value>

                                    <ControlTemplate TargetType="Button">

                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="18">

                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>

                                        </Border>

                                        <ControlTemplate.Triggers>

                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#99FFFFFF"/>

                                                <Setter Property="FontSize"
                                                        Value="27"/>

                                            </Trigger>

                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>

                                </Setter.Value>

                            </Setter>

                        </Style>

                    </Button.Style>

                </Button>

                <!-- ПАПКА -->
                <TextBlock Text="Папка сохранений"
                           FontFamily="Oswald"
                           FontSize="18"
                           Margin="0,30,0,5"
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <TextBox Name="SaveFolderTextBox"
                             Width="240"
                             Height="35"
                             FontSize="14"
                             IsReadOnly="True"/>

                    <Button Name="BrowseFolderButton"
                            Content="..."
                            Width="40"
                            Height="35"
                            Margin="10,0,0,0"
                            Click="BrowseFolderButton_Click"/>

                </StackPanel>

                <!-- ФОРМАТ -->
                <TextBlock Text="Формат сохранения"
                           FontFamily="Oswald"
                           FontSize="18"
                           Margin="0,20,0,5"
                           HorizontalAlignment="Center"/>

                <ComboBox Grid.Row="5"
                          Grid.Column="1"
                          Name="FormatComboBox"
                          Width="150"
                          Height="35"
                          FontSize="16">

                    <ComboBoxItem Content="JSON"
                                  IsSelected="True"/>

                    <ComboBoxItem Content="XML"/>

                </ComboBox>

                <!-- ОШИБКИ -->
                <TextBlock Name="ErrorTextBlock"
                           Foreground="Red"
                           FontSize="14"
                           Margin="0,20,0,0"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>