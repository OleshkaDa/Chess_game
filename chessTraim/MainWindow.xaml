<Window x:Class="chessTraim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шахматы" Height="350" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="♔ ШАХМАТЫ ♚" 
                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Button Grid.Row="1" Grid.ColumnSpan="2" Name="NewGameButton" 
                Content="Новая игра" FontSize="18" Padding="10" Margin="0,5"
                Click="NewGameButton_Click" Height="50"/>

        <Button Grid.Row="2" Grid.ColumnSpan="2" Name="ContinueButton" 
                Content="Продолжить игру" FontSize="18" Padding="10" Margin="0,5"
                Click="ContinueButton_Click" IsEnabled="False" Height="50"/>

        <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,15" Height="2" Background="Gray"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Папка для сохранения:" 
                   VerticalAlignment="Center" FontSize="14" Margin="0,5"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
            <TextBox Name="SaveFolderTextBox" Width="250" Margin="0,0,5,0" IsReadOnly="True"/>
            <Button Name="BrowseFolderButton" Content="Обзор" Width="60" Click="BrowseFolderButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Формат сохранения:" 
                   VerticalAlignment="Center" FontSize="14" Margin="0,5"/>
        <ComboBox Grid.Row="5" Grid.Column="1" Name="FormatComboBox" 
                  Width="120" Margin="5,0,0,0" HorizontalAlignment="Left">
            <ComboBoxItem Content="JSON" IsSelected="True"/>
            <ComboBoxItem Content="XML"/>
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Name="ErrorTextBlock" 
                   Foreground="Red" TextWrapping="Wrap" Margin="0,10"/>
    </Grid>
</Window>