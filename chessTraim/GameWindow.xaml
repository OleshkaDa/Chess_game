<Window x:Class="chessTraim.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шахматы" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Closing="GameWindow_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <TextBlock Name="TurnTextBlock" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>
            <TextBlock Name="CheckTextBlock" FontSize="16" Foreground="Red" Margin="0,0,20,0"/>
            <TextBlock Name="GameOverTextBlock" FontSize="16" Foreground="DarkGreen" FontWeight="Bold"/>
        </StackPanel>

        <Grid Name="ChessBoardGrid" Grid.Row="1" Width="500" Height="500" 
              HorizontalAlignment="Center" VerticalAlignment="Center">
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="UndoButton" Content="ОТменить ход" Width="120" Height="35" Margin="5" Click="UndoButton_Click"/>
            <Button Name="SaveButton" Content="Сохраниться" Width="100" Height="35" Margin="5" Click="SaveButton_Click"/>
            <Button Name="ExitButton" Content="Выйти" Width="100" Height="35" Margin="5" Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>