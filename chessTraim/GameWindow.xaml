<Window x:Class="chessTraim.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шахматы"
        Height="600"
        Width="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Closing="GameWindow_Closing">

    <Grid>

        <!-- ФОН -->
        <Grid.Background>

            <ImageBrush ImageSource="Images/board.png"
                    Stretch="UniformToFill"
                    Opacity="0.12"/>

        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0"
            Background="#88FFFFFF"
            CornerRadius="15"
            Margin="20"
            Padding="10">

            <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">

                <TextBlock Name="TurnTextBlock"
                       FontSize="24"
                       FontFamily="Oswald"
                       FontWeight="Bold"
                       Margin="20,0"/>

                <TextBlock Name="CheckTextBlock"
                       FontSize="24"
                       FontFamily="Oswald"
                       Foreground="Red"
                       Margin="20,0"/>

                <TextBlock Name="GameOverTextBlock"
                       FontSize="24"
                       FontFamily="Oswald"
                       Foreground="DarkGreen"
                       FontWeight="Bold"
                       Margin="20,0"/>

            </StackPanel>

        </Border>

        <!-- ДОСКА -->
        <Viewbox Grid.Row="1"
             Stretch="Uniform">

            <Grid Name="ChessBoardGrid"
              Width="800"
              Height="800"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            </Grid>

        </Viewbox>

        <!-- НИЖНИЕ КНОПКИ -->
        <Border Grid.Row="2"
            Background="#88FFFFFF"
            CornerRadius="15"
            Margin="20"
            Padding="10">

            <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">

                <Button Name="UndoButton"
                    Content="Отменить ход"
                    Width="170"
                    Height="50"
                    Margin="10"
                    FontSize="20"
                    FontFamily="Oswald"
                    Click="UndoButton_Click"/>

                <Button Name="SaveButton"
                    Content="Сохранить"
                    Width="170"
                    Height="50"
                    Margin="10"
                    FontSize="20"
                    FontFamily="Oswald"
                    Click="SaveButton_Click"/>

                <Button Name="ExitButton"
                    Content="Выйти"
                    Width="170"
                    Height="50"
                    Margin="10"
                    FontSize="20"
                    FontFamily="Oswald"
                    Click="ExitButton_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>